rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only owner can read/write, but onboardingCompleted can be read by app
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Usernames: public read, write only via Cloud Function (deny direct)
    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }
    // User sessions (for multi-device management)
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // Deny all others
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Social collections
match /posts/{postId} {
  allow read: if true;
  allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
  allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
}
match /posts/{postId}/likes/{likeId} {
  allow read: if true;
  allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
  allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
}
match /feeds/{feedId} {
  allow read: if request.auth != null && request.auth.uid == resource.data.userId;
  allow write: if false; // only Cloud Function
}
match /stories/{storyId} {
  allow read: if true;
  allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
  allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
}
match /messages/{messageId} {
  allow read: if request.auth != null && resource.data.conversationId in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
  allow create: if request.auth != null;
}
match /conversations/{convId} {
  allow read: if request.auth != null && resource.data.participants has request.auth.uid;
  allow create: if request.auth != null;
}
match /notifications/{notificationId} {
  allow read: if request.auth != null && resource.data.userId == request.auth.uid;
  allow write: if false;
}
match /userSearch/{userId} {
  allow read: if true;
  allow write: if false;
}
